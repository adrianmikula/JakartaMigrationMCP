package adrianmikula.jakartamigration.intellij.integration;

import adrianmikula.jakartamigration.advancedscanning.service.AdvancedScanningService;
import adrianmikula.jakartamigration.platforms.service.PlatformDetectionService;
import adrianmikula.jakartamigration.refactor.service.RecipeExecutionService;
import adrianmikula.jakartamigration.scanning.service.DependencyAnalysisService;
import lombok.extern.slf4j.Slf4j;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.DisplayName;

import java.io.IOException;
import java.nio.file.Path;

import static org.junit.jupiter.api.Assertions.*;

/**
 * Integration tests using real GitHub projects to test scans and refactor recipes.
 * PREMIUM FEATURE - Available only in premium edition.
 * 
 * These tests use actual open-source projects that contain javax.* dependencies
 * to validate our migration tools work correctly on real-world codebases.
 */
@Slf4j
public class RealGitHubProjectsIntegrationTest extends IntegrationTestBase {
    
    @Test
    @DisplayName("Should analyze Spring Boot project with javax.validation")
    void shouldAnalyzeSpringBootProjectWithJavaxValidation() throws IOException {
        // This test uses a real Spring Boot project with javax.validation dependencies
        // URL: https://github.com/javaee-samples/javaee7-samples/tree/main/jakartamigration/validation
        
        // For now, we'll test with a local mock project structure
        Path projectPath = createMockSpringBootProject();
        
        // Test dependency analysis
        var analysisResult = dependencyAnalysisService.analyzeProject(projectPath);
        assertNotNull(analysisResult);
        assertTrue(analysisResult.dependencyGraph().nodeCount() > 0);
        
        // Test platform detection
        var platformResult = platformDetectionService.detectPlatforms(projectPath);
        assertNotNull(platformResult);
        
        // Test advanced scanning
        var scanResult = advancedScanningService.performAdvancedScan(projectPath, "reflection");
        assertNotNull(scanResult);
        
        log.info("Successfully analyzed Spring Boot project with javax.validation");
    }
    
    @Test
    @DisplayName("Should analyze servlet project with javax.servlet")
    void shouldAnalyzeServletProjectWithJavaxServlet() throws IOException {
        // This test uses a real servlet project with javax.servlet dependencies
        // URL: https://github.com/javaee-samples/javaee7-samples/tree/main/jakartamigration/servlet
        
        Path projectPath = createMockServletProject();
        
        // Test dependency analysis
        var analysisResult = dependencyAnalysisService.analyzeProject(projectPath);
        assertNotNull(analysisResult);
        assertTrue(analysisResult.dependencyGraph().nodeCount() > 0);
        
        // Test for javax.servlet dependencies
        boolean hasJavaxServlet = analysisResult.dependencyGraph().getNodes().stream()
            .anyMatch(node -> node.artifactId().toLowerCase().contains("servlet"));
        assertTrue(hasJavaxServlet, "Should detect javax.servlet dependencies");
        
        log.info("Successfully analyzed servlet project with javax.servlet");
    }
    
    @Test
    @DisplayName("Should execute refactor recipes on real project")
    void shouldExecuteRefactorRecipesOnRealProject() throws IOException {
        // Test recipe execution on a project with javax dependencies
        Path projectPath = createMockProjectWithJavaxDependencies();
        
        // Test recipe execution
        var recipes = recipeExecutionService.getAvailableRecipes();
        assertNotNull(recipes);
        assertFalse(recipes.isEmpty());
        
        // Execute a simple package rename recipe
        var executionResult = recipeExecutionService.executeRecipe(
            "javax.servlet.to.jakarta.servlet", 
            projectPath
        );
        assertNotNull(executionResult);
        
        log.info("Successfully executed refactor recipes on real project");
    }
    
    @Test
    @DisplayName("Should perform comprehensive migration analysis")
    void shouldPerformComprehensiveMigrationAnalysis() throws IOException {
        // Test full migration workflow on a complex project
        Path projectPath = createMockComplexProject();
        
        // 1. Dependency Analysis
        var dependencyResult = dependencyAnalysisService.analyzeProject(projectPath);
        assertNotNull(dependencyResult);
        
        // 2. Platform Detection
        var platformResult = platformDetectionService.detectPlatforms(projectPath);
        assertNotNull(platformResult);
        
        // 3. Advanced Scanning
        var reflectionResult = advancedScanningService.performAdvancedScan(projectPath, "reflection");
        var configResult = advancedScanningService.performAdvancedScan(projectPath, "configuration");
        
        // 4. Recipe Recommendations
        var recipes = recipeExecutionService.getRecommendedRecipes(dependencyResult);
        assertNotNull(recipes);
        
        // Verify all components work together
        assertTrue(dependencyResult.dependencyGraph().nodeCount() > 0);
        assertNotNull(reflectionResult);
        assertNotNull(configResult);
        assertFalse(recipes.isEmpty());
        
        log.info("Successfully performed comprehensive migration analysis");
    }
    
    @Test
    @DisplayName("Should handle large enterprise project structure")
    void shouldHandleLargeEnterpriseProjectStructure() throws IOException {
        // Test with a multi-module enterprise project structure
        Path projectPath = createMockEnterpriseProject();
        
        // Test that our tools can handle complex project structures
        var analysisResult = dependencyAnalysisService.analyzeProject(projectPath);
        assertNotNull(analysisResult);
        
        // Should detect multiple modules
        assertTrue(analysisResult.dependencyGraph().nodeCount() > 10);
        
        // Should handle transitive dependencies
        var transitiveCount = analysisResult.dependencyGraph().getNodes().stream()
            .filter(node -> !node.isDirect())
            .count();
        assertTrue(transitiveCount > 0, "Should detect transitive dependencies");
        
        log.info("Successfully handled large enterprise project structure");
    }
    
    // Helper methods to create mock project structures for testing
    // In the future, these will be replaced with real GitHub project downloads
    
    private Path createMockSpringBootProject() throws IOException {
        Path projectPath = tempDir.resolve("spring-boot-validation");
        Files.createDirectories(projectPath);
        
        // Create pom.xml with javax.validation dependency
        String pomXml = """
            <?xml version="1.0" encoding="UTF-8"?>
            <project xmlns="http://maven.apache.org/POM/4.0.0">
                <modelVersion>4.0.0</modelVersion>
                <groupId>com.example</groupId>
                <artifactId>spring-boot-validation</artifactId>
                <version>1.0.0</version>
                
                <dependencies>
                    <dependency>
                        <groupId>javax.validation</groupId>
                        <artifactId>validation-api</artifactId>
                        <version>2.0.1.Final</version>
                    </dependency>
                    <dependency>
                        <groupId>org.springframework.boot</groupId>
                        <artifactId>spring-boot-starter-web</artifactId>
                        <version>2.7.0</version>
                    </dependency>
                </dependencies>
            </project>
            """;
        
        Files.write(projectPath.resolve("pom.xml"), pomXml.getBytes());
        
        // Create src directory structure
        Path srcDir = projectPath.resolve("src/main/java/com/example");
        Files.createDirectories(srcDir);
        
        // Create sample Java file with javax.validation imports
        String javaCode = """
            package com.example;
            
            import javax.validation.constraints.NotNull;
            import javax.validation.constraints.Size;
            
            public class User {
                @NotNull
                @Size(min = 2, max = 50)
                private String name;
                
                // getters and setters
            }
            """;
        
        Files.write(srcDir.resolve("User.java"), javaCode.getBytes());
        
        return projectPath;
    }
    
    private Path createMockServletProject() throws IOException {
        Path projectPath = tempDir.resolve("servlet-project");
        Files.createDirectories(projectPath);
        
        // Create pom.xml with javax.servlet dependency
        String pomXml = """
            <?xml version="1.0" encoding="UTF-8"?>
            <project xmlns="http://maven.apache.org/POM/4.0.0">
                <modelVersion>4.0.0</modelVersion>
                <groupId>com.example</groupId>
                <artifactId>servlet-project</artifactId>
                <version>1.0.0</version>
                
                <dependencies>
                    <dependency>
                        <groupId>javax.servlet</groupId>
                        <artifactId>javax.servlet-api</artifactId>
                        <version>4.0.1</version>
                        <scope>provided</scope>
                    </dependency>
                </dependencies>
            </project>
            """;
        
        Files.write(projectPath.resolve("pom.xml"), pomXml.getBytes());
        
        // Create web.xml
        Path webInfDir = projectPath.resolve("src/main/webapp/WEB-INF");
        Files.createDirectories(webInfDir);
        
        String webXml = """
            <?xml version="1.0" encoding="UTF-8"?>
            <web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
                     xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                     xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
                     http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
                     version="4.0">
                     
                <servlet>
                    <servlet-name>ExampleServlet</servlet-name>
                    <servlet-class>com.example.ExampleServlet</servlet-class>
                </servlet>
            </web-app>
            """;
        
        Files.write(webInfDir.resolve("web.xml"), webXml.getBytes());
        
        return projectPath;
    }
    
    private Path createMockProjectWithJavaxDependencies() throws IOException {
        Path projectPath = tempDir.resolve("javax-project");
        Files.createDirectories(projectPath);
        
        // Create pom.xml with multiple javax dependencies
        String pomXml = """
            <?xml version="1.0" encoding="UTF-8"?>
            <project xmlns="http://maven.apache.org/POM/4.0.0">
                <modelVersion>4.0.0</modelVersion>
                <groupId>com.example</groupId>
                <artifactId>javax-project</artifactId>
                <version>1.0.0</version>
                
                <dependencies>
                    <dependency>
                        <groupId>javax.servlet</groupId>
                        <artifactId>javax.servlet-api</artifactId>
                        <version>4.0.1</version>
                    </dependency>
                    <dependency>
                        <groupId>javax.persistence</groupId>
                        <artifactId>javax.persistence-api</artifactId>
                        <version>2.2</version>
                    </dependency>
                    <dependency>
                        <groupId>javax.ejb</groupId>
                        <artifactId>javax.ejb-api</artifactId>
                        <version>3.2.2</version>
                    </dependency>
                </dependencies>
            </project>
            """;
        
        Files.write(projectPath.resolve("pom.xml"), pomXml.getBytes());
        
        return projectPath;
    }
    
    private Path createMockComplexProject() throws IOException {
        Path projectPath = tempDir.resolve("complex-project");
        Files.createDirectories(projectPath);
        
        // Create multi-module project structure
        String parentPom = """
            <?xml version="1.0" encoding="UTF-8"?>
            <project xmlns="http://maven.apache.org/POM/4.0.0">
                <modelVersion>4.0.0</modelVersion>
                <groupId>com.example</groupId>
                <artifactId>complex-project</artifactId>
                <version>1.0.0</version>
                <packaging>pom</packaging>
                
                <modules>
                    <module>web-module</module>
                    <module>data-module</module>
                    <module>common-module</module>
                </modules>
            </project>
            """;
        
        Files.write(projectPath.resolve("pom.xml"), parentPom.getBytes());
        
        // Create sub-modules
        for (String module : new String[]{"web-module", "data-module", "common-module"}) {
            Path modulePath = projectPath.resolve(module);
            Files.createDirectories(modulePath);
            
            String modulePom = String.format("""
                <?xml version="1.0" encoding="UTF-8"?>
                <project xmlns="http://maven.apache.org/POM/4.0.0">
                    <modelVersion>4.0.0</modelVersion>
                    <parent>
                        <groupId>com.example</groupId>
                        <artifactId>complex-project</artifactId>
                        <version>1.0.0</version>
                    </parent>
                    <artifactId>%s</artifactId>
                    
                    <dependencies>
                        <dependency>
                            <groupId>javax.servlet</groupId>
                            <artifactId>javax.servlet-api</artifactId>
                            <version>4.0.1</version>
                        </dependency>
                    </dependencies>
                </project>
                """, module);
            
            Files.write(modulePath.resolve("pom.xml"), modulePom.getBytes());
        }
        
        return projectPath;
    }
    
