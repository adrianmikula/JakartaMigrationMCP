# Git attributes for cross-platform development
# Ensures consistent line endings and file handling across Windows, Linux, and macOS

# =============================================================================
# LINE ENDING NORMALIZATION
# =============================================================================

# Normalize line endings for all text files
# Git will convert LF to CRLF on checkout (Windows) and CRLF to LF on commit
* text=auto

# Explicitly set line endings for specific file types

# Source code files - always LF (Unix style)
*.java text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.scala text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.properties text eol=lf
*.gradle text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf

# Configuration files
*.conf text eol=lf
*.config text eol=lf
*.ini text eol=lf
*.toml text eol=lf
*.tsp text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.vue text eol=lf

# Documentation
*.rst text eol=lf
*.adoc text eol=lf
*.tex text eol=lf

# =============================================================================
# BINARY FILES - NO LINE ENDING CONVERSION
# =============================================================================

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.ico binary
*.svg binary
*.webp binary

# Archives and compressed files
*.zip binary
*.jar binary
*.war binary
*.ear binary
*.tar binary
*.gz binary
*.bz2 binary
*.xz binary
*.7z binary
*.rar binary

# Executables and libraries
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.class binary
*.pyc binary

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary

# Media files
*.mp3 binary
*.mp4 binary
*.avi binary
*.mov binary
*.wav binary
*.flac binary

# Database files
*.db binary
*.sqlite binary
*.sqlite3 binary

# =============================================================================
# GENERATED FILES - NO LINE ENDING CONVERSION
# =============================================================================

# Build outputs
build/ binary
out/ binary
target/ binary
node_modules/ binary
.gradle/ binary
.idea/ binary
.vscode/ binary

# Generated sources
generated-sources/ binary
generated-test-sources/ binary

# Log files
*.log binary

# Temporary files
*.tmp binary
*.temp binary
*.swp binary
*.swo binary

# =============================================================================
# SPECIAL HANDLING
# =============================================================================

# Git configuration files
.gitattributes text eol=lf
.gitignore text eol=lf
.gitmodules text eol=lf

# License and legal files
LICENSE text eol=lf
NOTICE text eol=lf
COPYRIGHT text eol=lf

# README files
README* text eol=lf
CHANGELOG* text eol=lf
CONTRIBUTING* text eol=lf
SECURITY* text eol=lf
CLA* text eol=lf

# Gradle wrapper files
gradlew text eol=lf
gradlew.bat text eol=crlf

# Maven wrapper files
mvnw text eol=lf
mvnw.cmd text eol=crlf

# =============================================================================
# LANGUAGE SPECIFIC SETTINGS
# =============================================================================

# Java/Kotlin - ensure consistent encoding
*.java text eol=lf diff=java
*.kt text eol=lf diff=kotlin
*.kts text eol=lf diff=kotlin

# XML/HTML - proper diff handling
*.xml text eol=lf diff=xml
*.html text eol=lf diff=html
*.xhtml text eol=lf diff=html

# JSON/YAML - structured diff
*.json text eol=lf diff=json
*.yaml text eol=lf diff=yaml
*.yml text eol=lf diff=yaml

# Markdown - diff without line numbers
*.md text eol=lf diff=markdown

# =============================================================================
# SECURITY SENSITIVE FILES
# =============================================================================

# Never diff these files (they contain sensitive data)
*.pem binary
*.key binary
*.crt binary
*.p12 binary
*.jks binary
*.keystore binary

# Environment files with secrets
.env.* binary
*.env binary
secrets.* binary

# =============================================================================
# WORKFLOW AUTOMATION FILES
# =============================================================================

# GitHub Actions - LF line endings
.github/workflows/*.yml text eol=lf
.github/workflows/*.yaml text eol=lf

# CI/CD configuration files
.gitlab-ci.yml text eol=lf
.travis.yml text eol=lf
.appveyor.yml text eol=crlf
azure-pipelines.yml text eol=lf

# Docker files
Dockerfile* text eol=lf
docker-compose*.yml text eol=lf
docker-compose*.yaml text eol=lf

# =============================================================================
# DOCUMENTATION GENERATION
# =============================================================================

# Javadoc and API docs
javadoc/ binary
api/ binary
docs/api/ binary

# Site generation
_site/ binary
public/ binary
dist/ binary

# =============================================================================
# DEVELOPMENT TOOL CONFIGURATION
# =============================================================================

# IDE configuration files - preserve line endings
.idea/** text eol=lf
.vscode/** text eol=lf
.eclipse/** text eol=lf
.netbeans/** text eol=lf

# Linting and formatting configuration
.eslintrc* text eol=lf
.prettierrc* text eol=lf
.editorconfig text eol=lf

# Build tool configuration
pom.xml text eol=lf
build.gradle* text eol=lf
settings.gradle* text eol=lf
gradle.properties text eol=lf

# =============================================================================
# TESTING
# =============================================================================

# Test reports and coverage
**/reports/ binary
**/coverage/ binary
**/surefire-reports/ binary
**/failsafe-reports/ binary

# Test outputs
test-results/ binary
test-output/ binary
